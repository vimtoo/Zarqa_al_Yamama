# ============================================================================
# ZARQA AL YAMAMA - Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================================

# Application Settings
ENVIRONMENT=development
APP_NAME=Zarqa al Yamama
APP_VERSION=1.0.0
CREATOR=Qusai Al-Duaij

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# ============================================================================
# LLM & AI PROVIDERS
# ============================================================================

# OpenRouter (Primary LLM Provider)
OPENROUTER_API_KEY=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

# DeepSeek (Secondary LLM Provider)
DEEPSEEK_API_KEY=sk-30e0de16e169451da19f2f672c8ec7f8

# OpenAI (Fallback)
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================================
# DATA SOURCE API KEYS
# ============================================================================

# News & Events Intelligence
GDELT_API_KEY=your-gdelt-key-here
NEWSAPI_KEY=your-newsapi-key-here

# Financial Market Data
POLYGON_API_KEY=your-polygon-key-here
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here
FMP_API_KEY=your-fmp-key-here
EODHD_API_KEY=your-eodhd-key-here

# Economic Data
WORLD_BANK_KEY=your-world-bank-key-here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL (Time-Series & Transactional Data)
DATABASE_URL=postgresql://zarqa:zarqa_pass@postgres:5432/zarqa_db
DB_HOST=postgres
DB_PORT=5432
DB_USER=zarqa
DB_PASSWORD=zarqa_pass
DB_NAME=zarqa_db

# Qdrant (Vector Database)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your-qdrant-key-here

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_pass

# Redis (Cache & Session State)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=redis_pass

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

TEMPORAL_ANALYST_ENABLED=true
CONTEXT_INTERPRETER_ENABLED=true
QUANTIFIER_ENABLED=true
CRITIC_ENABLED=true
GOVERNOR_ENABLED=true

# Forecast Parameters
DEFAULT_FORECAST_HORIZON_DAYS=30
CONFIDENCE_THRESHOLD=0.60
SENTIMENT_WEIGHT=0.8
VOLATILITY_FACTOR_BASE=1.0

# ============================================================================
# CACHE & RATE LIMITING
# ============================================================================

CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============================================================================
# CORS & SECURITY
# ============================================================================

CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

LOG_FORMAT=json
SENTRY_DSN=your-sentry-dsn-here
ENABLE_METRICS=true
