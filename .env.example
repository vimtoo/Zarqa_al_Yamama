# Zarqa al Yamama - Environment Configuration Template
# COPY THIS FILE TO .env AND FILL IN YOUR KEYS
# DO NOT COMMIT THE REAL .env FILE

# App Configuration
APP_NAME="Zarqa al Yamama"
ENVIRONMENT="development"
LOG_LEVEL="INFO"

# ==========================================
# LLM Providers
# ==========================================
# OpenRouter (Primary)
OPENROUTER_API_KEY=""

# DeepSeek (Reasoning)
DEEPSEEK_API_KEY=""

# OpenAI (Fallback)
OPENAI_API_KEY=""

# Google Gemini (Optional - Search/Reasoning)
GEMINI_ENABLED="false"
GEMINI_API_KEY=""

# ==========================================
# Data Sources
# ==========================================
NEWSDATA_API_KEY=""
GDELT_API_KEY=""
NEWSAPI_KEY=""
GNEWS_API_KEY=""
ACLED_API_KEY=""
ACLED_EMAIL=""
ELECTIONS_API_KEY=""
LEGISLATION_API_KEY=""
POLYGON_API_KEY=""
ALPHA_VANTAGE_KEY=""

# ==========================================
# Infrastructure
# ==========================================
# Database
DATABASE_URL="postgresql://zarqa:zarqa_pass@postgres:5432/zarqa_db"

# Vector DB
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""

# Knowledge Graph
NEO4J_URI="neo4j://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"

# Cache
REDIS_URL="redis://localhost:6379"
